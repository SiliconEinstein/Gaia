      ],
      "metadata": {
        "prior": 0.9
      },
      "package": "galileo_fine",
      "parameters": [],
      "representative_content": "斜面实验2：重复实验百余次，结果偏差不超过脉搏一次，高度可重复。",
      "source_refs": [
        {
          "knowledge_name": "obs.theta2",
          "module": "default",
          "package": "galileo_fine",
          "version": "4.0.0"
        }
      ]
    },
    {
