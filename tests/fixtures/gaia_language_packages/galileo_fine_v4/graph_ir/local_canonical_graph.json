        "raw_c7c919dc6e7f330e"
      ],
      "metadata": null,
      "package": "galileo_fine",
      "parameters": [],
      "representative_content": "假设重物下落更快，复合体HL总重量大于H，因此HL速度应快于H。",
      "source_refs": [
        {
          "knowledge_name": "hyp.T2",
          "module": "default",
          "package": "galileo_fine",
          "version": "4.0.0"
        }
      ]
    },
