      ],
      "metadata": {
        "prior": 0.9
      },
      "package": "galileo_fine",
      "parameters": [],
      "representative_content": "斜面实验1：不同重量的球沿抛光沟槽滚下，所经距离之比等于时间之比的平方，与球重量无关。",
      "source_refs": [
        {
          "knowledge_name": "obs.theta1",
          "module": "default",
          "package": "galileo_fine",
          "version": "4.0.0"
        }
      ]
    },
    {
      "kind": "observation",
      "knowledge_type": "claim",
