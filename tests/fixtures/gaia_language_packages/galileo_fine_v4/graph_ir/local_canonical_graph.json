      ],
      "metadata": null,
      "package": "galileo_fine",
      "parameters": [],
      "representative_content": "物体下落速度与其重量成正比：重物比轻物下落更快。",
      "source_refs": [
        {
          "knowledge_name": "hyp.A",
          "module": "default",
          "package": "galileo_fine",
          "version": "4.0.0"
        }
