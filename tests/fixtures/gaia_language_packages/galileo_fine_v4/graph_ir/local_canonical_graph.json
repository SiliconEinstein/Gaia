      "metadata": null,
      "package": "galileo_fine",
      "parameters": [],
      "representative_content": "假设重物下落更快，将重球H与轻球L绑在一起，L拖拽H，复合体HL速度应慢于H。",
      "source_refs": [
        {
          "knowledge_name": "hyp.T1",
          "module": "default",
          "package": "galileo_fine",
          "version": "4.0.0"
        }
      ]
    },
    {
      "kind": null,
