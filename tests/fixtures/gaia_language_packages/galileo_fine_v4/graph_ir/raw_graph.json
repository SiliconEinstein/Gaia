    },
    {
      "content": "物体下落速度与其重量成正比：重物比轻物下落更快。",
      "kind": null,
      "knowledge_type": "claim",
      "metadata": null,
      "parameters": [],
      "raw_node_id": "raw_ba45819aab54c1e5",
      "source_refs": [
