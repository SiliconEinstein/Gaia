          "knowledge_name": "hyp.V_w2",
          "module": "default",
          "package": "galileo_coarse",
          "version": "4.0.0"
        }
      ]
    },
    {
      "content": "斜面实验的证据表明，在真空中不同重量的物体以相同速率下落。",
      "kind": null,
      "knowledge_type": "claim",
      "metadata": null,
      "parameters": [],
