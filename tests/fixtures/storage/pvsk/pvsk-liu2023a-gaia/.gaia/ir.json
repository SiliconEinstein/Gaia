      "type": "claim"
    },
    {
      "content": "DMDP-treated devices with 1.5 cm2 area deliver a PCE of 24.0%, demonstrating scalability of the passivation approach",
      "content_hash": "1a22550d651aae08fe1fb5132ea3e3345aff1893160393a1871b3f684875a4df",
      "declaration_index": 13,
