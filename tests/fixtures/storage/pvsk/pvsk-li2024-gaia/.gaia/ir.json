{
  "ir_hash": "sha256:cccd7d5c5d090a3606b0442cef25b2516535b21e1b03d538a3d5e176bce25623",
  "knowledges": [
    {
      "content": "FA-dominated perovskite (FA0.93Cs0.07PbI3) with antisolvent-free deposition. Module structure: glass/FTO/SnO2/perovskite/passivator/spiro-OMeTAD/Au. Small devices (0.14 cm2), large devices (1.04 cm2), mini-modules (13.44 cm2), and fully slot-die printed large modules (310 cm2 and 802 cm2).",
      "content_hash": "6d01e5147ee88655a990070fe5e18b01404e811b3de8ac633413ca9783551aac",
      "declaration_index": 0,
      "exported": true,
      "id": "pvsk:pvsk_li2024::exp_context",
      "label": "exp_context",
      "parameters": [],
      "type": "setting"
    },
    {
      "content": "Phase separation occurs in double-halide alloyed 2D perovskites with long-chain (>10) alkylamine ligands, producing uneven n-value distribution on 3D perovskite surfaces. This energy disorder deteriorates interfacial charge transport in large-area modules.",
      "content_hash": "23f9235259df0ec0514ede3ba78b85d0db184080274138794c368e1beb5a464a",
      "declaration_index": 1,
      "exported": true,
      "id": "pvsk:pvsk_li2024::phase_problem",
      "label": "phase_problem",
      "parameters": [],
      "type": "setting"
    },
    {
      "content": "Long-chain alkylamine ligands (>10 carbons) cause phase separation in double-halide alloyed 2D perovskites, while triple-halide compositions successfully eliminate the problematic phase separation",
      "content_hash": "005dd8891de0ce65134a51fca01976e29b8b0201e773b0fa6fa78daee5da3398",
      "declaration_index": 2,
      "exported": true,
      "id": "pvsk:pvsk_li2024::phase_separation_discovery",
      "label": "phase_separation_discovery",
      "metadata": {
        "prior": 0.85
      },
      "parameters": [],
      "title": "phase_separation_discovery",
      "type": "claim"
    },
    {
      "content": "Incorporating formamidinium bromide (FABr) into n-dodecylammonium halide (DAX) post-treatment enables growth of phase-pure n=2 2D perovskite capping layer with homogeneous morphology on 3D perovskite surfaces",
      "content_hash": "ae3f2fb30ee6bf65398f82773d30ebfad34a47cdc68d48af06d17dbd3df132e4",
      "declaration_index": 3,
      "exported": true,
