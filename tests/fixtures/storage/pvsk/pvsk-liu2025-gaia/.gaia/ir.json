{
  "ir_hash": "sha256:1a98483bbc38021afe4501c0b5734db3a398c05ca6457b5fafa1ae0a061f39ff",
  "knowledges": [
    {
      "content": "All-perovskite tandem solar cells with WBG (~1.78 eV) FA0.8Cs0.2Pb(I0.62Br0.38)3 top cell and NBG (~1.25 eV) Pb-Sn perovskite bottom cell. Device areas 0.049 cm2 and 1.05 cm2. Certified by JET (Japan Electrical Safety and Environment Technology Laboratories). PEDOT:PSS HTL with sulfanilic acid (SA) dipolar passivation.",
      "content_hash": "f6489cd9d0209b09909eae2bdf5c620d648c2db649877cf2f0e90fb08b3bb855",
      "declaration_index": 0,
      "exported": true,
      "id": "pvsk:pvsk_liu2025::exp_context",
      "label": "exp_context",
      "parameters": [],
      "type": "setting"
    },
    {
      "content": "Deep-level traps at the buried perovskite/HTL interface in mixed Pb-Sn NBG subcells cause severe non-radiative recombination. Conventional long-chain amine passivation improves Voc but impairs charge transport, reducing Jsc and FF due to insulating barriers.",
      "content_hash": "577790926fddd7214dc7fe3e19ef6a63682e3e3e57dfb0069022d9b661660385",
      "declaration_index": 1,
      "exported": true,
      "id": "pvsk:pvsk_liu2025::buried_interface_problem",
      "label": "buried_interface_problem",
      "parameters": [],
      "type": "setting"
    },
    {
      "content": "A dipolar-passivation strategy using sulfanilic acid (SA) at the HTL/Pb-Sn perovskite interface reduces trap density while enabling precise energy-level alignment through oriented dipoles, simultaneously suppressing recombination and enhancing carrier extraction",
      "content_hash": "1912e58020060bff3659c7ba992023c0dde7b44977f03ba38caa47f66075eeaf",
      "declaration_index": 2,
      "exported": true,
      "id": "pvsk:pvsk_liu2025::dipolar_passivation_strategy",
      "label": "dipolar_passivation_strategy",
      "metadata": {
        "prior": 0.85
      },
      "parameters": [],
      "title": "dipolar_passivation_strategy",
      "type": "claim"
    },
    {
      "content": "Dipolar-passivated Pb-Sn PSCs achieve 24.9% PCE with Voc of 0.911 V, Jsc of 33.1 mA cm-2, and FF of 82.6%, representing one of the highest reported PCEs for mixed Pb-Sn PSCs",
      "content_hash": "16a256e9080e3d6f6dbf1dadc58050da75324f804907003eac3e7afa569bfb86",
      "declaration_index": 3,
      "exported": true,
