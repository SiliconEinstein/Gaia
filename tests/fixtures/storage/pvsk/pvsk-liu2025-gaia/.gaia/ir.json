      "parameters": [],
      "title": "nbg_pce_24_9_percent",
      "type": "claim"
    },
    {
      "content": "All-perovskite tandem solar cells with dipolar passivation achieve 30.6% PCE (certified stabilized 30.1% by JET) for 0.049 cm2 area",
      "content_hash": "34d9031b8909f30ab44fc6da656f96fa5416c07437daf90f5cc51e03b99e0282",
      "declaration_index": 4,
      "exported": true,
